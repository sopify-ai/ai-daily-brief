# DuckCoding API (OpenAI-compatible relay)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.duckcoding.ai/v1

# Optional: Notion integration
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-database-id

# Optional: model override
AI_NEWS_MODEL=gpt-5.4

# Feishu (Lark) webhook bot — optional, for push to Feishu group
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
FEISHU_WEBHOOK_SECRET=           # optional, for signed webhooks

